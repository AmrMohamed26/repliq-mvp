# ─────────────────────────────────────────────
# Repliq MVP — environment configuration
# Copy to `.env` and fill in values for local dev.
# ─────────────────────────────────────────────

# Redis (queue + sessions + pub/sub)
REDIS_URL=redis://localhost:6379

# Supabase Storage (temporary replacement for Cloudflare R2)
# SUPABASE_URL: https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY: service-role key (server/worker only; never expose client-side)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=repliq-mvp
# Required public HTTPS base URL for generated assets.
# Usually: https://<project-ref>.supabase.co/storage/v1/object/public/<bucket>
SUPABASE_PUBLIC_BASE_URL=

# Worker tuning (raise WORKER_CONCURRENCY on 16GB+ Macs for faster batches)
WORKER_CONCURRENCY=3
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_RETRIES=2

# Render output
RENDER_FPS=30
RENDER_WIDTH=1920
RENDER_HEIGHT=1080
# Remotion per-lead speed (2 = safe default; use 1 if low RAM)
RENDER_CONCURRENCY=2
REMOTION_CRF=20

# Local filesystem
TMP_DIR=/tmp/repliq

# Protected-site screenshots (Upwork, LinkedIn) — optional paid APIs
# Get keys: https://www.scrapingbee.com/ | https://www.zenrows.com/
# SCREENSHOT_PROVIDER=scrapingbee | zenrows | auto  (auto = ScrapingBee then ZenRows)
SCRAPINGBEE_API_KEY=
ZENROWS_API_KEY=
SCREENSHOT_PROVIDER=scrapingbee

# Logged-in Upwork / LinkedIn screenshots (Cookie-Editor JSON exports)
# COOKIES_DIR=cookies
# Place cookies/upwork.json and cookies/linkedin.json — see cookies/README.md

# Logging
LOG_LEVEL=info

# Public app config (must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_APP_NAME=Repliq
# Public HTTPS URL where this Next app is deployed (required for Gmail thumbnails in sent mail).
# Email images use {NEXT_PUBLIC_APP_URL}/api/media/thumb/[leadId]; watch links use /v/[leadId].
# Production (Vercel): https://repliq-mvp.vercel.app
# localhost works for local UI only — recipients cannot load images from localhost.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel: set PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 (vercel.json sets this for installs).
# Run the BullMQ worker on Railway/Render/VPS with the same REDIS_URL — not on Vercel.
